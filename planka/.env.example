# ============================================================
# Planka Environment Configuration
# ============================================================

# --- Application ---
BASE_URL=http://localhost:3000
SECRET_KEY=changeme_supersecretkey # openssl rand -hex 64
LOG_LEVEL=info

# Optional: if behind reverse proxy (e.g., Traefik, Nginx)
# TRUST_PROXY=true

# Maximum upload file size in bytes (e.g., 52428800 = 50MB)
# MAX_UPLOAD_FILE_SIZE=52428800

# Token expiration in days
# TOKEN_EXPIRES_IN=365

# Default app language
# DEFAULT_LANGUAGE=en-US

# ============================================================
# Default Admin Account
# ============================================================
# If you don’t want to create via UI, uncomment and set:
# DEFAULT_ADMIN_EMAIL=admin@example.com
# DEFAULT_ADMIN_PASSWORD=StrongPassword123!
# DEFAULT_ADMIN_NAME=Administrator
# DEFAULT_ADMIN_USERNAME=admin

# ============================================================
# PostgreSQL Database
# ============================================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_dbpassword
POSTGRES_DB=planka
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Compose-compatible DATABASE_URL
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}/${POSTGRES_DB}

# ============================================================
# SMTP Email (optional)
# ============================================================
# SMTP_HOST=smtp.mailserver.com
# SMTP_PORT=587
# SMTP_NAME=Planka Notifications
# SMTP_SECURE=true
# SMTP_USER=notifications@example.com
# SMTP_PASSWORD=changeme_smtppass
# SMTP_FROM="Planka" <notifications@example.com>

# ============================================================
# S3 / Object Storage (optional)
# ============================================================
# S3_ENDPOINT=https://s3.example.com
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=planka-files
# S3_FORCE_PATH_STYLE=true

# ============================================================
# OIDC / SSO Integration (optional)
# ============================================================
# OIDC_ISSUER=https://auth.example.com
# OIDC_CLIENT_ID=planka
# OIDC_CLIENT_SECRET=changeme_oidcsecret
# OIDC_SCOPES=openid email profile
# OIDC_ADMIN_ROLES=admin
# OIDC_PROJECT_OWNER_ROLES=project_owner
# OIDC_BOARD_USER_ROLES=board_user
# OIDC_ENFORCED=true

# ============================================================
# Gravatar / Avatar Proxy (optional)
# ============================================================
# GRAVATAR_BASE_URL=https://your-proxy.example.com/avatar/

# ============================================================
# Container Configuration
# ============================================================
# Uncomment and set if needed
# UID=1000
# GID=1000

# ============================================================
# Miscellaneous
# ============================================================
# STORAGE_LIMIT= # in bytes
# ACTIVE_USERS_LIMIT=
# SHOW_DETAILED_AUTH_ERRORS=false